# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.

# Google Cloud project (used by ADK to call Gemini via Vertex AI)
GOOGLE_CLOUD_PROJECT=your-gcp-project-id

# Optional: force a specific region for Vertex AI
# GOOGLE_CLOUD_LOCATION=us-central1

# Optional: use Gemini Developer API key instead of ADK/Vertex
# GOOGLE_API_KEY=your-api-key-here

# Local dev port
PORT=8080
